# DATABASE
DATABASE_URL=""              # PostgreSQL pooled — e.g. postgresql://user:pass@host:5432/payflow
DATABASE_URL_UNPOOLED=""     # PostgreSQL direct (for Prisma migrations)
DATABASE_URL_TEST=""         # Separate PostgreSQL for integration tests

# AUTH
NEXTAUTH_SECRET=""           # Generate with: openssl rand -base64 32
NEXTAUTH_URL=""              # http://localhost:3000 in dev, real URL in prod
GOOGLE_CLIENT_ID=""          # From Google Cloud Console OAuth credentials
GOOGLE_CLIENT_SECRET=""

# REDIS
REDIS_URL=""                 # redis://localhost:6379

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=""           # https://yourdomain.com,https://www.yourdomain.com

# MERCADO PAGO
# Get credentials at: https://www.mercadopago.com/developers/panel/app
MP_ACCESS_TOKEN=""           # TEST-... for sandbox, APP_USR-... for production
MP_WEBHOOK_SECRET=""         # Secret to verify x-signature header

# STRIPE
# Get credentials at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""         # sk_test_... for test, sk_live_... for production
# Get webhook secret at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""     # whsec_... — different for local (stripe listen) and production

# MOCK PROVIDER — only for development and tests, blocked in production
PAYMENT_PROVIDER=mock        # mercadopago | stripe | mock
MOCK_PAYMENT_BEHAVIOR=success  # success | fail | timeout | pending
MOCK_WEBHOOK_DELAY_MS=2000

# APP
NODE_ENV=development
PORT=3001
LOG_LEVEL=info               # debug | info | warn | error
WEBHOOK_TIMEOUT_MS=8000      # Max timeout for outgoing webhooks in ms

# EMAIL — for subscription dunning and payment confirmations
RESEND_API_KEY=""            # Get at: https://resend.com
EMAIL_FROM="PayFlow <noreply@yourdomain.com>"

# ENCRYPTION — for encrypting sensitive secrets stored in DB (e.g. 2FA TOTP secret)
ENCRYPTION_KEY=""            # Generate with: openssl rand -base64 32
